generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cartao_ferramenta {
  id            Int         @id @default(autoincrement())
  codigo_uid    String?     @db.VarChar(100)
  ativo         Boolean?
  ferramenta_id Int?
  ferramenta    ferramenta? @relation(fields: [ferramenta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cartao_operador {
  id           Int       @id @default(autoincrement())
  codigo_uid   String?   @db.VarChar(100)
  ativo        Boolean?
  cpf_operador String?   @db.VarChar(11)
  operador     operador? @relation(fields: [cpf_operador], references: [cpf], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model emprestimo {
  id             Int         @id @default(autoincrement())
  operador_cpf   String?     @db.VarChar(11)
  ferramenta_id  Int?
  data_retirada  DateTime?   @db.Timestamp(6)
  data_devolucao DateTime?   @db.Timestamp(6)
  status         String?     @db.VarChar(20)
  ferramenta     ferramenta? @relation(fields: [ferramenta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operador       operador?   @relation(fields: [operador_cpf], references: [cpf], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model estoque {
  id Int @id @default(autoincrement())
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ferramenta {
  id                 Int                  @id @default(autoincrement())
  tipo               String?              @db.VarChar(50)
  cartao_ferramenta  cartao_ferramenta[]
  emprestimo         emprestimo[]
  ferramenta_estoque ferramenta_estoque[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ferramenta_estoque {
  id            Int        @id @default(autoincrement())
  ferramenta_id Int
  quantidade    Int?       @default(0)
  status_saude  String?    @db.VarChar(50)
  localizacao   String?    @db.VarChar(50)
  ferramenta    ferramenta @relation(fields: [ferramenta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leitura_nfc {
  id        Int       @id @default(autoincrement())
  data_hora DateTime? @default(now()) @db.Timestamp(6)
  uid_lido  String?   @db.VarChar(100)
  sensor_id Int?
  sensor    sensor?   @relation(fields: [sensor_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model operador {
  cpf             String            @id @db.VarChar(11)
  setor           String?           @db.VarChar(50)
  cartao_operador cartao_operador[]
  emprestimo      emprestimo[]
  usuario         usuario           @relation(fields: [cpf], references: [cpf], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sensor {
  id          Int           @id @default(autoincrement())
  tipo        String?       @db.VarChar(50)
  medida      String?       @db.VarChar(50)
  leitura_nfc leitura_nfc[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usuario {
  cpf      String    @id @db.VarChar(11)
  nome     String    @db.VarChar(100)
  tipo     String    @db.VarChar(20)
  operador operador?
}
